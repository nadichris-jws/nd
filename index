      if (konfirmasi) {
        // 1. Hapus semua data yang tersimpan di LocalStorage
        localStorage.removeItem("marqueeTeks");

        // 2. Refresh halaman untuk mengembalikan nilai asli dari kode HTML
        location.reload();
      }
