<script>
function updateCountdown(){
  if(!window.jadwal) return;

  const now   = new Date();
  const today = new Date();

  const list = [
    { n:"Subuh",   t: jadwal.subuh },
    { n:"Dzuhur",  t: jadwal.dzuhur },
    { n:"Ashar",   t: jadwal.ashar },
    { n:"Maghrib", t: jadwal.maghrib },
    { n:"Isya",    t: jadwal.isya }
  ];

  let next = null;

  // cari sholat berikutnya hari ini
  list.forEach(j => {
    const [h,m] = j.t.split(":");
    const d = new Date(
      today.getFullYear(),
      today.getMonth(),
      today.getDate(),
      h, m, 0
    );

    if(d > now && !next){
      next = {...j, d};
    }
  });

  /* ===== JIKA SEMUA SHOLAT HARI INI SUDAH LEWAT ===== */
  if(!next){
    // ambil waktu Subuh BESOK
    const [h,m] = jadwal.subuh.split(":");
    const besokSubuh = new Date(
      today.getFullYear(),
      today.getMonth(),
      today.getDate() + 1,
      h, m, 0
    );

    next = {
      n: "Subuh",
      d: besokSubuh
    };
  }

  /* ===== HITUNG SELISIH WAKTU ===== */
  const diff = next.d - now;
  const totalDetik = Math.floor(diff / 1000);											 
const h = String(Math.floor(diff / 3600000)).padStart(2,"0");
  const m = String(Math.floor((diff % 3600000) / 60000)).padStart(2,"0");
  const s = String(Math.floor((diff % 60000) / 1000)).padStart(2,"0");

  countdown.textContent =
    `${next.n.toUpperCase()} :  ${h}: ${m}: ${s}`;

  /* LOGIKA 5 MENIT MENJELANG ADZAN */
  const overlay = document.getElementById("universalOverlay");
  const overlayCD = document.getElementById("overlayCountdown");
  const overlayStatus = document.getElementById("overlayStatus");
  const beep = document.getElementById("beepAudio");

  // 1. Menuju Adzan (5 Menit sebelum)
  if (totalDetik <= 300 && totalDetik > 0) {
    overlay.style.display = "flex";
    overlayStatus.textContent = "MENUJU ADZAN";
    overlayCD.textContent = `${m}:${s}`;
  } 
  // 2. Saat Adzan (Beep 5 detik)
  else if (totalDetik === 0) {
    beep.play();
    overlay.style.display = "none";
    // Trigger Mode Iqomah setelah 5 detik adzan selesai
    setTimeout(() => { modeIqomahActive = true; window.iqomahEnd = new Date().getTime() + 600000; }, 5000);
  }
  // 3. Menuju Iqomah (10 Menit setelah Adzan)
  else if (modeIqomahActive) {
    const iqomahDiff = window.iqomahEnd - new Date().getTime();
    if (iqomahDiff > 0) {
      overlay.style.display = "flex";
      overlayStatus.textContent = "MENUJU IQOMAH";
      const im = String(Math.floor(iqomahDiff / 60000)).padStart(2,"0");
      const is = String(Math.floor((iqomahDiff % 60000) / 1000)).padStart(2,"0");
      overlayCD.textContent = `${im}:${is}`;
    } else {
      overlay.style.display = "none";
      modeIqomahActive = false;
    }
  }
  else {
    overlay.style.display = "none";
  }
}

setInterval(updateCountdown, 1000);
</script>



