<script>
/* ====== Parse CSV ====== */
function parseCSV(text){
  const lines = text.split(/\r?\n/).filter(l=>l.trim()!=="");
  lines.shift();
  return lines.map(line=>{
    const cells=[], cur={v:"",q:false};
    for(let c of line){
      if(c=='"'){cur.q=!cur.q;continue;}
      if(c==',' && !cur.q){cells.push(cur.v);cur.v='';continue;}
      cur.v+=c;
    }
    cells.push(cur.v);
    return cells.map(c=>c.trim());
  });
}

const rows = parseCSV(rawData);

/* ===== Cari hari ini ===== */
function getTodayRow(){
  const now = new Date();
  const d = String(now.getDate()).padStart(2,'0');
  const m = String(now.getMonth()+1).padStart(2,'0');
  const y = now.getFullYear();
  const today = `${d}/${m}/${y}`;
  return rows.find(r => r[0].includes(today));
}

const today = getTodayRow();

